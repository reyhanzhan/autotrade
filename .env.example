# ============================================================================
# AUTOTRADE — Environment Configuration
# ============================================================================
# Copy this file to `.env` and fill in the values. NEVER commit .env to git.
# Generate ENCRYPTION_KEY with: npm run keygen
# ============================================================================

# --- Database -------------------------------------------------------------
# SQLite default (zero-config, low-RAM). For MySQL, change to:
#   DATABASE_URL="mysql://user:pass@127.0.0.1:3306/autotrade"
# and update prisma/schema.prisma provider to "mysql".
DATABASE_URL="file:./prisma/autotrade.db"

# --- Master Encryption Key (REQUIRED) -------------------------------------
# 32 random bytes, base64-encoded. Used to AES-256-GCM-encrypt API keys
# before storing them in the DB. Losing this key = losing all saved keys.
# Generate with:  npm run keygen
ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_KEY"

# --- Bot runtime ----------------------------------------------------------
# Set TESTNET=true to use Binance Futures Testnet. Default is true.
# Get testnet API keys from: https://testnet.binancefuture.com/
TESTNET="true"

# Comma-separated watchlist (uppercase). The screener scans ALL of these every
# closed candle and picks the highest-confidence signal. Override per-config
# in the DB via POST /api/config { "watchlist": [...] }.
SYMBOLS="BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,LINKUSDT,AVAXUSDT"

# Comma-separated symbols to exclude from manual watchlists and auto-discovery.
SYMBOL_BLACKLIST="ZECUSDT,BELUSDT,XLMUSDT"

# Auto-discovery liquidity scan controls.
AUTO_DISCOVER_SYMBOLS="false"
MAX_SCREENER_SYMBOLS="20"
MIN_24H_QUOTE_VOLUME="30000000"
MAX_ENTRY_SPREAD_PCT="0.05"
MAX_SAME_SIDE_POSITIONS="2"

# K-Line interval. Higher TF = stronger SMC signals but slower.
# Valid: 1m, 3m, 5m, 15m, 30m, 1h, 4h, 1d
INTERVAL="15m"

# Default leverage when no DB config exists yet.
DEFAULT_LEVERAGE="5"

# Risk per trade as % of available balance (e.g. 0.3 = 0.3%).
DEFAULT_RISK_PERCENT="0.3"

# How many candles to keep in memory per symbol for SMC analysis.
CANDLE_HISTORY="500"

# Minimum final confidence required to actually place an order.
MIN_CONFIDENCE="0.68"
DYNAMIC_CONFIDENCE_ENABLED="true"
STRONG_TREND_ADX="25"
RANGING_ADX="20"
STRONG_TREND_MIN_CONFIDENCE="0.65"
TREND_PULLBACK_MIN_CONFIDENCE="0.66"
FIB_SETUP_MIN_CONFIDENCE="0.75"
RANGING_MIN_CONFIDENCE="0.75"
HIGH_RISK_SHORT_MIN_CONFIDENCE="0.75"
AUTO_BLACKLIST_ENABLED="true"
AUTO_BLACKLIST_LOOKBACK_DAYS="7"
AUTO_BLACKLIST_DAYS="14"
AUTO_BLACKLIST_MIN_TRADES="3"
AUTO_BLACKLIST_MAX_WIN_RATE="0.3"
AUTO_BLACKLIST_LOSS_STREAK="3"
BTC_REGIME_ENABLED="true"
BTC_CRASH_1H_PCT="2"
BTC_CRASH_4H_PCT="4"
BTC_RANGING_ADX="18"
BTC_RANGING_ATR_PCT="0.8"

# Set to "false" to run strategy in dry-run (signals logged, no orders sent).
LIVE_TRADING="false"

# How often the position reconciler polls Binance for fills/closures (ms).
RECONCILER_INTERVAL_MS="30000"

# --- Coinglass (OPTIONAL confluence layer) --------------------------------
# Boosts/penalizes signal confidence using funding rate, open interest,
# long/short ratio, and 24h liquidation data. The bot still works fully
# without these — confluence multiplier just defaults to 1.0 (neutral).
# Get a key at: https://www.coinglass.com/pricing
COINGLASS_API_KEY=""
COINGLASS_BASE_URL="https://open-api-v3.coinglass.com"
# How long to cache Coinglass responses (ms). 5 min = 300000.
COINGLASS_CACHE_MS="300000"

# --- Web dashboard --------------------------------------------------------
WEB_PORT="3000"

# Bearer token required by /api/* routes. Long random string.
# Generate with:  npm run keygen
DASHBOARD_API_TOKEN="REPLACE_WITH_LONG_RANDOM_TOKEN"

# --- Logging --------------------------------------------------------------
LOG_LEVEL="info"   # trace | debug | info | warn | error
